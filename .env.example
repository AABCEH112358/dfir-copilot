# Copy to .env and fill in real values. .env is gitignored.

# LLM provider key (shared by all agents' Gemini adapters).
# Band never sees this — it's used directly against the Gemini API.
GEMINI_API_KEY=your-gemini-api-key

# Per-agent Band API keys. Band issues one API key per agent; grab each from
# that agent's page in the Band UI (app.band.ai/agents). The variable names
# here must match the `api_key_env` fields in agent_config.yaml.
LIAISON_API_KEY=band-api-key-for-DFIR-Liaison
CLASSIFIER_API_KEY=band-api-key-for-DFIR-Classifier
HOST_FORENSICS_API_KEY=band-api-key-for-DFIR-HostForensics
NETWORK_FORENSICS_API_KEY=band-api-key-for-DFIR-NetworkForensics
CAPTAIN_API_KEY=band-api-key-for-DFIR-Captain

# Deprecated: single shared key used as a fallback when a per-agent key above
# is not set. Prefer the per-agent variables; this exists only for backwards
# compatibility and will emit a warning when used.
# BAND_API_KEY=band-api-key
